# llm-bridge-server environment variables.
#
# Every value here mirrors a default from internal/config/config.go — copy
# this file to .env (or export the vars in your shell / systemd unit) and
# tweak as needed. Defaults are sane for a local single-user deploy, so
# most fields can be left as-is.

# --- core server -----------------------------------------------------------

# HTTP listen address. Bind to localhost only by default.
LLMBRIDGE_LISTEN_ADDR=:8160

# Externally-reachable URL advertised to llm-bridge-runner daemons when
# they ask where to fetch harness binaries. Empty falls back to the
# runner's own server_url — fine for the WSL-via-tunnel case.
# LLMBRIDGE_PUBLIC_URL=https://bridge.example.com

# --- store backing files ---------------------------------------------------

LLMBRIDGE_DB_PATH=~/.llm-bridge/bridge.db

LLMBRIDGE_AGENT_DB=~/.config/agent-store/agents.db
LLMBRIDGE_MEMORY_DB=~/.config/memory-store/memory.db
LLMBRIDGE_HARNESS_DB=~/.config/harness-store/harness.db
LLMBRIDGE_HOOK_DB=~/.config/hook-store/hooks.db
LLMBRIDGE_MODEL_STORE_DB=~/.config/model-store/store.db
LLMBRIDGE_SNAPSHOT_DB=~/.config/snapshot-store/snapshots.db
LLMBRIDGE_SNAPSHOT_GIT=~/.config/snapshot-store/snapshots.git

# --- sibling service URLs --------------------------------------------------

LLMBRIDGE_LOG_STORE_URL=http://localhost:8175
LLMBRIDGE_TOOL_STORE_URL=http://localhost:8302
LLMBRIDGE_PERMISSION_STORE_URL=http://localhost:8304

# Optional services — leave empty to disable the related code paths.
# LLMBRIDGE_MODEL_STORE_URL=http://localhost:8401
# LLMBRIDGE_AGENT_STORE_URL=http://localhost:8402

# auth-store is consulted by harness manifests for credential resolution.
# When running outside the kayushkin host, point these at your own
# auth-store deployment (or leave AUTH_STORE_TOKEN empty for an unauthed
# local dev setup — the service will return 401 for every secret lookup).
# AUTH_STORE_URL=http://localhost:8303
# AUTH_STORE_TOKEN=

# --- on-disk paths ---------------------------------------------------------

LLMBRIDGE_BRIDGE_PREFS=~/.config/llm-bridge/bridge-prefs.json
LLMBRIDGE_CONFORMANCE_PATH=~/.config/llm-bridge/conformance.json
LLMBRIDGE_IMAGES_DIR=images

# --- runner-binary serving (only relevant if you serve remote runners) ----

# Directory of prebuilt runner + harness wrapper binaries. Served by
# /api/runner/binary and /api/runner/install.sh.
LLMBRIDGE_RUNNER_ASSETS_DIR=/usr/local/lib/llm-bridge-runner-binaries
# LLMBRIDGE_RUNNER_INSTALL_SCRIPT=/path/to/install.sh

# --- behavior tuning -------------------------------------------------------

# `source:folder` pairs for auto-filing newly created sessions into
# sidebar folders by their session.source field.
LLMBRIDGE_SOURCE_FOLDERS=scheduler:Scheduled,autoworker:Scheduled,healthcheck:Scheduled,renamer:Auto-rename,conformance:Conformance,subagent:Subagents

# Per-session pty ring buffer (bytes). Late attachers receive a replay of
# this much terminal output so xterm.js can paint the current screen.
LLMBRIDGE_PTY_RING_BUFFER_BYTES=65536

# Per-harness reverse-proxy overrides for /api/harness-proxy/{name}/...
# Defaults: inber=http://localhost:8200, hermes=http://localhost:8500.
# Set to empty string to disable a harness's proxy.
# LLMBRIDGE_HARNESS_PROXY_INBER=http://localhost:8200
# LLMBRIDGE_HARNESS_PROXY_HERMES=http://localhost:8500
