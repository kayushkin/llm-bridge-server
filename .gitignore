llm-bridge
llm-bridge-server
mock-harness

# Host-local config (machine-specific systemd drop-ins, dev secrets, etc.).
# Put anything that should never leave this machine under ./.local/
/.local/

# Defensive: never accidentally commit credentials.
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*
credentials.*
secrets.*

# The globs above target secret *data* files, but they also match Go source
# (credentials.* swallowed internal/harness/credentials.go, which left the
# committed tree unbuildable while `git status` stayed clean). Source is never
# a secret. Files under /.local/ stay ignored — git cannot re-include through
# an excluded directory.
!*.go
